# Copy this file to .env.local and fill in real values.

# Supabase project
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: restrict magic-link sign-in to one or more company domains.
# Comma-separated, no @ prefix. Leave blank to allow any email.
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAINS=

# AI analysis
# Set to "false" to call OpenAI for real. Defaults to fixture data so the
# dashboard is fully demoable with zero API cost or key.
USE_AI_FIXTURES=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
